---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="bg-white dark:bg-gray-950 border-t border-gray-100 dark:border-gray-800 py-12 md:py-16 transition-colors duration-300">
  <div class="container mx-auto px-4 lg:px-8 max-w-6xl">
    <div class="flex flex-col items-center">
      
      <a href={`/${lang}/`} class="text-2xl md:text-3xl font-extrabold mb-6 bg-linear-to-r from-primary-500 to-secondary-500 bg-clip-text text-transparent hover:opacity-80 transition-opacity">
        Jonnathan Aguilar
      </a>
      
      <div class="flex flex-wrap justify-center gap-x-6 gap-y-3 mb-8 text-sm font-bold text-gray-500 dark:text-gray-400">
        <a href="#about" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{t('nav.about')}</a>
        <a href="#skills" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{t('nav.skills')}</a>
        <a href="#portfolio" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{t('nav.portfolio')}</a>
        <a href="#experience" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{t('nav.experience')}</a>
      </div>

      <div class="flex justify-center gap-4 mb-10">
        <a href="https://github.com/JonnathanAguilar" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300 hover:bg-white hover:text-gray-900 dark:hover:bg-white dark:hover:text-gray-900 flex items-center justify-center transition-all duration-300 shadow-sm hover:shadow-md">
          <i class="fab fa-github"></i>
        </a>
        <a href="https://www.linkedin.com/in/jonnathan-aguilar-lalvay" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300 hover:bg-[#0A66C2] hover:text-white hover:border-transparent flex items-center justify-center transition-all duration-300 shadow-sm hover:shadow-md">
          <i class="fab fa-linkedin-in"></i>
        </a>
        <a href="https://x.com/jaguilarlalvay" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black hover:border-transparent flex items-center justify-center transition-all duration-300 shadow-sm hover:shadow-md">
          <i class="fa-brands fa-twitter"></i>
        </a>
        <a href="https://www.instagram.com/jonnathan_aguilarl" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300 hover:bg-[#E1306C] hover:text-white hover:border-transparent flex items-center justify-center transition-all duration-300 shadow-sm hover:shadow-md">
          <i class="fab fa-instagram"></i>
        </a>
      </div>
      
      <div class="text-center space-y-3">
        <p class="text-gray-500 dark:text-gray-400 text-sm font-medium">
          &copy; {new Date().getFullYear()} Jonnathan Aguilar. {t('footer.rights')}
        </p>
        <p class="text-gray-400 dark:text-gray-500 text-xs flex items-center justify-center gap-1.5">
          {t('footer.designedWith')} <i class="fas fa-heart text-red-500 animate-pulse"></i> {t('footer.using')} 
          <span class="font-bold text-gray-700 dark:text-gray-300">Astro</span> {t('footer.and')} 
          <span class="font-bold text-gray-700 dark:text-gray-300">Tailwind CSS</span>
        </p>
      </div>
      
    </div>
  </div>
</footer>