---
export interface Props {
  class?: string;
  showTextOnMobile?: boolean;
}

const { class: className = "", showTextOnMobile = false } = Astro.props;

// Detectar el idioma actual leyendo la URL
const pathname = Astro.url.pathname;
const currentLang = pathname.startsWith("/en") ? "en" : "es";

// Definir valores para el idioma opuesto (el destino)
const targetLang = currentLang === "es" ? "en" : "es";

// Reemplazar el prefijo del idioma en la URL actual para ir a la misma página en el otro idioma
let targetUrl = pathname.replace(`/${currentLang}`, `/${targetLang}`);
if (!targetUrl.startsWith(`/${targetLang}`)) {
  targetUrl = `/${targetLang}/`; // Fallback de seguridad
}

const targetTextMobile = targetLang === "en" ? "English" : "Español";
const targetTextDesktop = targetLang === "en" ? "EN" : "ES";
const flagUrl =
  targetLang === "en"
    ? "https://flagcdn.com/w20/gb.png"
    : "https://flagcdn.com/w20/es.png";

// Texto dinámico para el tooltip según el idioma actual
const tooltipPrefix = currentLang === "es" ? "Cambiar a" : "Change to";
---

<a
  href={targetUrl}
  class={`lang-switcher-btn flex items-center gap-2 px-4 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-primary-100 dark:hover:bg-primary-900 transition ${className}`}
  title={`${tooltipPrefix} ${targetTextMobile}`}
>
  <img
    src={flagUrl}
    width="20"
    alt={targetTextMobile}
    class="rounded-xs shadow-sm"
  />

  <span class="text-sm font-medium">
    {showTextOnMobile ? targetTextMobile : targetTextDesktop}
  </span>
</a>