---
export interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<button 
  class={`theme-toggle-btn p-2 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 transition flex items-center justify-center w-10 h-10 ${className}`}
  aria-label="Alternar tema oscuro/claro"
>
  <span class="block dark:hidden">
    <i class="fas fa-moon text-lg"></i>
  </span>
  
  <span class="hidden dark:block text-yellow-400">
    <i class="fas fa-sun text-lg"></i>
  </span>
</button>

<script>
  // Esta función envuelve la lógica para que no haya conflictos
  const setupThemeToggles = () => {
    const toggleTheme = () => {
      document.documentElement.classList.toggle('dark');
      const isDark = document.documentElement.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    };

    // Buscamos todos los botones que tengan esta clase y les asignamos el evento
    const buttons = document.querySelectorAll('.theme-toggle-btn');
    buttons.forEach(btn => {
      btn.removeEventListener('click', toggleTheme);
      btn.addEventListener('click', toggleTheme);
    });
  };

  // Ejecutamos la configuración
  setupThemeToggles();
  
  // Soporte para las transiciones de vista (View Transitions) de Astro
  document.addEventListener('astro:after-swap', setupThemeToggles);
</script>