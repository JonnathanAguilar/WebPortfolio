---
export interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<button 
  class={`theme-toggle-btn p-2 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 transition ${className}`}
  aria-label="Alternar tema oscuro/claro"
>
  <i class="fas fa-moon dark:hidden"></i>
  <i class="fas fa-sun hidden dark:inline"></i>
</button>

<script>
  // Esta función envuelve la lógica para que no haya conflictos
  const setupThemeToggles = () => {
    const toggleTheme = () => {
      document.documentElement.classList.toggle('dark');
      const isDark = document.documentElement.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    };

    // Buscamos todos los botones que tengan esta clase y les asignamos el evento
    const buttons = document.querySelectorAll('.theme-toggle-btn');
    buttons.forEach(btn => {
      // Evitamos asignar el evento múltiples veces
      btn.removeEventListener('click', toggleTheme);
      btn.addEventListener('click', toggleTheme);
    });
  };

  // Ejecutamos la configuración
  setupThemeToggles();
  
  // Soporte para las transiciones de vista (View Transitions) de Astro si las usas
  document.addEventListener('astro:after-swap', setupThemeToggles);
</script>