---
import type { AboutData } from '../../data/types';

export interface Props {
  data: AboutData;
}

const { data } = Astro.props;
---

<section id="about" class="py-20 bg-white dark:bg-gray-900">
  <div class="container mx-auto px-4">
    <div class="max-w-5xl mx-auto bg-white dark:bg-gray-800 rounded-2xl shadow-xl overflow-hidden">
      <div class="grid md:grid-cols-2">
        {/* Left Column - About Text */}
        <div class="p-8 md:p-10">
          <h2 class="text-3xl md:text-4xl font-bold mb-6 text-gray-800 dark:text-white relative inline-block">
            {data.title}
            <span class="absolute bottom-0 left-0 w-12 h-1 bg-primary-500 rounded-full mt-2"></span>
          </h2>
          <div class="space-y-4 text-gray-600 dark:text-gray-300">
            <p>{data.greeting}</p>
            <p>{data.description1}</p>
            <p>{data.description2}</p>
            <p>{data.description3}</p>
          </div>
        </div>
        
        {/* Right Column - Basic Info */}
        <div class="bg-linear-to-br from-primary-50 to-secondary-50 dark:from-gray-700 dark:to-gray-800 p-8 md:p-10">
          <h3 class="text-2xl font-bold mb-6 text-gray-800 dark:text-white">Información Básica</h3>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <i class="fas fa-user text-primary-500 mt-1 w-5"></i>
              <div>
                <p class="font-semibold text-gray-700 dark:text-gray-200">Edad</p>
                <p class="text-gray-600 dark:text-gray-400">{data.basicInfo.age} años</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <i class="fas fa-envelope text-primary-500 mt-1 w-5"></i>
              <div>
                <p class="font-semibold text-gray-700 dark:text-gray-200">Email</p>
                <a href={`mailto:${data.basicInfo.email}`} class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition">
                  {data.basicInfo.email}
                </a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <i class="fas fa-phone-alt text-primary-500 mt-1 w-5"></i>
              <div>
                <p class="font-semibold text-gray-700 dark:text-gray-200">Teléfono</p>
                <a href={`tel:${data.basicInfo.phone.replace(/\s/g, '')}`} class="text-gray-600 dark:text-gray-400 hover:text-primary-600 transition">
                  {data.basicInfo.phone}
                </a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <i class="fas fa-map-marker-alt text-primary-500 mt-1 w-5"></i>
              <div>
                <p class="font-semibold text-gray-700 dark:text-gray-200">Dirección</p>
                <p class="text-gray-600 dark:text-gray-400">{data.basicInfo.address}</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <i class="fas fa-language text-primary-500 mt-1 w-5"></i>
              <div>
                <p class="font-semibold text-gray-700 dark:text-gray-200">Idiomas</p>
                <p class="text-gray-600 dark:text-gray-400">{data.basicInfo.languages}</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <i class="fab fa-orcid text-primary-500 mt-1 w-5"></i>
              <div>
                <p class="font-semibold text-gray-700 dark:text-gray-200">ORCID</p>
                <a href={`https://orcid.org/${data.basicInfo.orcid}`} target="_blank" class="text-gray-600 dark:text-gray-400 hover:text-primary-600 transition">
                  {data.basicInfo.orcid}
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>