---
// src/components/sections/Education.astro
import type { EducationData } from '../../data/types';

export interface Props {
  data: EducationData;
}

const { data } = Astro.props;
---

<section id="education" class="py-20 bg-white dark:bg-gray-900">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 text-gray-800 dark:text-white" data-aos="fade-up">
      {data.title}
    </h2>
    
    <div class="max-w-4xl mx-auto space-y-6">
      {data.education.map((edu, index) => (
        <div 
          class="bg-gray-50 dark:bg-gray-800 rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-all hover:-translate-y-1"
          data-aos="fade-up"
          data-aos-delay={index * 100}
        >
          <div class="grid md:grid-cols-4">
            <div class="md:col-span-1 bg-linear-to-br from-primary-500 to-secondary-500 p-6 flex flex-col items-center justify-center text-white">
              <i class={`fas ${edu.type === 'university' ? 'fa-university' : 'fa-microchip'} text-4xl mb-3`}></i>
              <p class="text-sm text-center font-semibold">{edu.period}</p>
            </div>
            <div class="md:col-span-3 p-6">
              <h3 class="text-xl font-bold text-gray-800 dark:text-white mb-2">{edu.degree}</h3>
              <p class="text-primary-600 dark:text-primary-400 font-semibold mb-3">{edu.institution}</p>
              <p class="text-gray-600 dark:text-gray-300">{edu.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>