---
import type { Project } from "../../data/types";
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

export interface Props {
  projects: Project[];
  title: string;
}

const { projects, title } = Astro.props;

// Inicializar i18n
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="portfolio" class="py-24 bg-gray-50 dark:bg-gray-800/50">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="text-center mb-16" data-aos="fade-up">
      <h2
        class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-white inline-block relative"
      >
        {title}
        <span
          class="absolute -bottom-3 left-1/2 transform -translate-x-1/2 w-16 h-1.5 bg-primary-500 rounded-full"
        ></span>
      </h2>
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10 max-w-6xl mx-auto"
    >
      {
        projects.map((project, index) => (
          <div
            class="bg-white dark:bg-gray-800 rounded-3xl overflow-hidden shadow-lg border border-gray-100 dark:border-gray-700 flex flex-col group hover:shadow-2xl hover:-translate-y-2 transition-all duration-300"
            data-aos="fade-up"
            data-aos-delay={index * 100}
          >
            <a
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="relative overflow-hidden h-56 block"
            >
              <img
                src={project.image}
                alt={project.title}
                loading="lazy"
                class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700 ease-in-out"
                onerror={`this.src='https://placehold.co/600x400/e2e8f0/64748b?text=${t('portfolio.project')}'`}
              />
              {/* Etiqueta flotante */}
              <div class="absolute top-4 right-4 px-3 py-1 bg-white/90 dark:bg-gray-900/90 backdrop-blur-sm text-primary-600 dark:text-primary-400 text-xs rounded-full font-bold shadow-sm flex items-center gap-1.5">
                <i
                  class={
                    project.type === "github"
                      ? "fa-brands fa-github"
                      : "fas fa-globe"
                  }
                ></i>{" "}
                {project.type === "github" ? t('portfolio.repository') : t('portfolio.webApp')}
              </div>
            </a>

            {/* Contenido de la tarjeta */}
            <div class="p-6 md:p-8 flex flex-col grow">
              <h3 class="text-xl font-bold text-gray-800 dark:text-white mb-3 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors line-clamp-1">
                {project.title}
              </h3>

              <p class="text-gray-600 dark:text-gray-300 text-sm mb-6 grow line-clamp-3">
                {project.description}
              </p>

              {/* Etiquetas de Tecnologías */}
              <div class="flex flex-wrap gap-2 mb-8">
                {project.tech.split(", ").map((tech) => (
                  <span class="text-xs px-3 py-1 bg-primary-50 dark:bg-gray-700 text-primary-700 dark:text-primary-300 font-semibold rounded-lg border border-primary-100 dark:border-gray-600">
                    {tech}
                  </span>
                ))}
              </div>

              {/* Botón de Enlace */}
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-auto w-full py-3 px-4 bg-gray-50 dark:bg-gray-900 hover:bg-primary-500 hover:text-white dark:hover:bg-primary-600 text-gray-700 dark:text-gray-200 text-sm font-bold rounded-xl text-center transition-all duration-300 flex items-center justify-center gap-2 border border-gray-200 dark:border-gray-700 hover:border-transparent"
              >
                <span>
                  {project.type === "github"
                    ? t('portfolio.viewCode')
                    : t('portfolio.visitProject')}
                </span>
                <i
                  class={`fas ${project.type === "github" ? "fa-code-branch" : "fa-external-link-alt"}`}
                />
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>