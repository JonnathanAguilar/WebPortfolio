---
// src/components/sections/Publications.astro
import type { PublicationsData } from '../../data/types';

export interface Props {
  data: PublicationsData;
}

const { data } = Astro.props;
---

<section id="publications" class="py-20 bg-white dark:bg-gray-900">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 text-gray-800 dark:text-white" data-aos="fade-up">
      {data.title}
    </h2>
    
    <div class="max-w-4xl mx-auto">
      {data.publications.map((pub, index) => (
        <div 
          class="bg-gray-50 dark:bg-gray-800 rounded-2xl shadow-lg p-6 hover:shadow-xl transition-all"
          data-aos="fade-up"
          data-aos-delay={index * 100}
        >
          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-xl bg-primary-500 flex items-center justify-center text-white text-xl shrink-0">
              <i class="fas fa-book"></i>
            </div>
            <div class="flex-1">
              <h3 class="text-lg font-bold text-gray-800 dark:text-white mb-2">{pub.title}</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">{pub.authors}</p>
              <p class="text-sm text-primary-600 dark:text-primary-400 mb-3">{pub.journal}</p>
              <div class="flex flex-wrap gap-3">
                <a 
                  href={pub.link} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-sm text-primary-600 dark:text-primary-400 hover:gap-3 transition-all"
                >
                  <i class="fas fa-external-link-alt text-xs"></i>
                  <span>DOI: {pub.doi}</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>