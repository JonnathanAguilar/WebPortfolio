---
import type { PublicationsData } from '../../data/types';

export interface Props {
  data: PublicationsData;
}

const { data } = Astro.props;
---

<section id="publications" class="py-24 bg-white dark:bg-gray-900">
  <div class="container mx-auto px-4 lg:px-8">
    
    <div class="text-center mb-16" data-aos="fade-up">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-white inline-block relative">
        {data.title}
        <span class="absolute -bottom-3 left-1/2 transform -translate-x-1/2 w-16 h-1.5 bg-primary-500 rounded-full"></span>
      </h2>
    </div>
    
    <div class="max-w-4xl mx-auto space-y-6 lg:space-y-8">
      {data.publications.map((pub, index) => (
        <div 
          class="bg-white dark:bg-gray-800 rounded-3xl p-6 md:p-8 shadow-md border border-gray-100 dark:border-gray-700 hover:shadow-xl hover:border-primary-200 dark:hover:border-primary-800 transition-all duration-300 group flex flex-col sm:flex-row gap-5 md:gap-6 items-start"
          data-aos="fade-up"
          data-aos-delay={index * 100}
        >
          {/* Icono de la publicación */}
          <div class="w-14 h-14 md:w-16 md:h-16 rounded-2xl bg-primary-50 dark:bg-gray-700 flex items-center justify-center text-primary-500 text-2xl md:text-3xl shrink-0 group-hover:scale-110 group-hover:-rotate-3 transition-transform duration-300">
            <i class="fas fa-book-open"></i>
          </div>
          
          {/* Detalles de la publicación */}
          <div class="flex-1 w-full flex flex-col h-full">
            <h3 class="text-lg md:text-xl font-bold text-gray-800 dark:text-white mb-2 leading-snug group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
              {pub.title}
            </h3>
            
            <p class="text-sm md:text-base text-gray-600 dark:text-gray-300 mb-1 font-medium">
              <i class="fas fa-users text-gray-400 dark:text-gray-500 mr-1.5 text-xs"></i>
              {pub.authors}
            </p>
            
            <p class="text-sm md:text-base font-bold text-primary-600 dark:text-primary-400 mb-4">
              <i class="fas fa-bookmark text-primary-400/70 mr-1.5 text-xs"></i>
              {pub.journal}
            </p>
            
            {/* Enlace al DOI o Documento */}
            <div class="mt-auto pt-2 border-t border-gray-100 dark:border-gray-700">
              <a 
                href={pub.link} 
                target="_blank" 
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 mt-3 text-sm font-bold text-gray-700 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors w-max"
              >
                <span>Ver Publicación (DOI: {pub.doi})</span>
                <i class="fas fa-arrow-right text-xs transform group-hover:translate-x-1 transition-transform"></i>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>