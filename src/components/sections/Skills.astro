---
import type { SkillsData } from '../../data/types';

export interface Props {
  data: SkillsData;
}

const { data } = Astro.props;
---

<section id="skills" class="py-20 bg-gray-50 dark:bg-gray-800">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 text-gray-800 dark:text-white" data-aos="fade-up">
      {data.title}
    </h2>
    
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-2 gap-8">
        {data?.categories?.map((category, catIndex) => (
          <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-lg p-6 hover:shadow-xl transition-shadow" data-aos="fade-up" data-aos-delay={catIndex * 100}>
            <h3 class="text-xl font-bold mb-6 text-gray-800 dark:text-white border-l-4 border-primary-500 pl-3">
              {category.name}
            </h3>
            <div class="space-y-4">
              {category.skills?.map((skill, skillIndex) => (
                <div>
                  <div class="flex justify-between mb-2">
                    <span class="text-gray-700 dark:text-gray-300 font-medium">{skill.name}</span>
                    <span class="text-primary-600 dark:text-primary-400 font-semibold">{skill.level}%</span>
                  </div>
                  <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2 overflow-hidden">
                    <div 
                      class="bg-linear-to-r from-primary-500 to-secondary-500 h-2 rounded-full transition-all duration-1000"
                      style={{ width: `${skill.level}%` }}
                      data-aos="progress-full"
                      data-aos-duration="1500"
                    ></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>